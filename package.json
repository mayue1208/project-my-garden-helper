{
  "name": "plant-care-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "植物养护助手微信小程序",
  "scripts": {
    "dev:mp": "uni --platform mp-weixin",
    "build": "uni build",
    "lint": "eslint src --ext .ts,.vue --fix",
