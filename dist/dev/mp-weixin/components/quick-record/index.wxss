/* uni-app 全局变量入口 */
page {
  background-color: #f6f8f6;
  font-size: 28rpx;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  line-height: 1.6;
  box-sizing: border-box;
}
view,
text,
scroll-view {
  box-sizing: border-box;
}
button {
  border-radius: 12rpx;
  font-size: 28rpx;
}
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.08);
}
.btn-primary {
  background: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}
.btn-primary[disabled] {
  opacity: 0.5;
}
.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #8c8c8c;
}
.empty-state .sub {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
}
.fab {
  position: fixed;
  bottom: 160rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  color: #ffffff;
  font-size: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.12);
  z-index: 100;
}
.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 99;
}
.record-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 30rpx;
  border-radius: 16rpx 16rpx 0 0;
  z-index: 100;
  max-height: 70vh;
  overflow-y: auto;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 30rpx;
}
.field {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.label {
  width: 100rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  flex-shrink: 0;
}
.value-text {
  font-size: 28rpx;
  color: #1a1a2e;
}
.type-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 0;
}
.type-btn {
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  background: #f0f0f0;
  font-size: 26rpx;
}
.type-btn.active {
  background: #e8f5e9;
  color: #1b8a3d;
}
.note-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 26rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 12rpx;
}
.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}
.cancel-btn {
  flex: 1;
  background: #f0f0f0;
  color: #8c8c8c;
  border: none;
  border-radius: 30rpx;
}
.submit-btn {
  flex: 1;
  background: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 30rpx;
}