/* uni-app 全局变量入口 */
page {
  background-color: #f6f8f6;
  font-size: 28rpx;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  line-height: 1.6;
  box-sizing: border-box;
}
view,
text,
scroll-view {
  box-sizing: border-box;
}
button {
  border-radius: 12rpx;
  font-size: 28rpx;
}
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.08);
}
.btn-primary {
  background: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}
.btn-primary[disabled] {
  opacity: 0.5;
}
.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #8c8c8c;
}
.empty-state .sub {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
}
.fab {
  position: fixed;
  bottom: 160rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  color: #ffffff;
  font-size: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.12);
  z-index: 100;
}
.page {
  padding-bottom: 40rpx;
}
.timeline-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 24rpx;
  background: #ffffff;
}
.plant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a2e;
}
.add-btn {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}
.filter-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f0f0;
}
.filter-item {
  display: flex;
  align-items: center;
}
.filter-label {
  font-size: 26rpx;
  color: #bfbfbf;
  margin-right: 8rpx;
}
.filter-value {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 500;
}
.filter-sep {
  font-size: 24rpx;
  color: #bfbfbf;
  margin: 0 16rpx;
}
.timeline {
  padding: 20rpx 30rpx;
}
.month-group {
  margin-bottom: 40rpx;
}
.month-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.month-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #8c8c8c;
  margin-right: 16rpx;
}
.month-line {
  flex: 1;
  height: 1rpx;
  background: #f0f0f0;
}
.event-node {
  display: flex;
  margin-bottom: 24rpx;
  position: relative;
  padding-left: 30rpx;
}
.dot {
  position: absolute;
  left: 0;
  top: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #07c160;
}
.event-card {
  flex: 1;
  padding: 16rpx;
  overflow: hidden;
}
.event-photo {
  width: 100%;
  height: 300rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}
.event-info {
  padding: 8rpx 0;
}
.event-type {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
}
.event-date-text {
  font-size: 26rpx;
  color: #bfbfbf;
  display: block;
  margin-top: 8rpx;
}
.event-desc {
  font-size: 26rpx;
  color: #8c8c8c;
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}