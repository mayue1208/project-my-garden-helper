<view class="page"><view class="timeline-header"><text class="plant-name">{{a}}{{b}}</text><text wx:if="{{c}}" class="add-btn" bindtap="{{d}}">+ 记录</text></view><view class="filter-bar"><view class="filter-item"><text class="filter-label">从</text><picker mode="date" fields="month" value="{{f}}" bindchange="{{g}}"><text class="filter-value">{{e}}</text></picker></view><text class="filter-sep">至</text><view class="filter-item"><picker mode="date" fields="month" value="{{i}}" bindchange="{{j}}"><text class="filter-value">{{h}}</text></picker></view></view><block wx:if="{{k}}"><view wx:if="{{l}}" class="empty-state"><text>{{m}}</text><text class="sub">完成养护后会自动记录</text></view><view wx:elif="{{n}}" class="empty-state"><text>该时间段暂无养护记录</text></view><view wx:else class="timeline"><view wx:for="{{o}}" wx:for-item="group" wx:key="c" class="month-group"><view class="month-header"><text class="month-label">{{group.a}}</text><view class="month-line"/></view><view wx:for="{{group.b}}" wx:for-item="r" wx:key="h" class="event-node"><view class="dot"/><view class="event-card card"><view class="event-info"><text class="event-type">{{r.a}} {{r.b}}</text><text class="event-date-text">{{r.c}}</text><text wx:if="{{r.d}}" class="event-desc">操作人：{{r.e}}</text><text wx:if="{{r.f}}" class="event-desc">{{r.g}}</text></view></view></view></view></view></block><block wx:else><view wx:if="{{p}}" class="empty-state"><text>{{q}}</text><text class="sub">开始记录植物的成长吧</text></view><view wx:elif="{{r}}" class="empty-state"><text>该时间段暂无成长记录</text></view><view wx:else class="timeline"><view wx:for="{{s}}" wx:for-item="group" wx:key="c" class="month-group"><view class="month-header"><text class="month-label">{{group.a}}</text><view class="month-line"/></view><view wx:for="{{group.b}}" wx:for-item="e" wx:key="g" class="event-node"><view class="dot"/><view class="event-card card"><image wx:if="{{e.a}}" src="{{e.b}}" class="event-photo" mode="aspectFill"/><view class="event-info"><text class="event-type">{{e.c}}</text><text class="event-date-text">{{e.d}}</text><text wx:if="{{e.e}}" class="event-desc">{{e.f}}</text></view></view></view></view></view></block></view>