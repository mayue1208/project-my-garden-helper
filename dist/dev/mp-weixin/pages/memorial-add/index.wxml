<view class="page"><view class="form card"><view class="field"><text class="label">选择植物</text><picker bindchange="{{b}}" range="{{c}}"><text class="value-text">{{a}}</text></picker></view><view class="field"><text class="label">类型</text><picker bindchange="{{e}}" range="{{f}}"><text class="value-text">{{d}}</text></picker></view><view class="field"><text class="label">日期</text><picker mode="date" bindchange="{{h}}"><text class="value-text">{{g}}</text></picker></view><view class="field"><text class="label">原因</text><input placeholder="如：浇水过多烂根" class="input" maxlength="100" value="{{i}}" bindinput="{{j}}"/></view><view wx:if="{{k}}" class="field"><text class="label">赠予</text><input placeholder="赠予对象" class="input" maxlength="20" value="{{l}}" bindinput="{{m}}"/></view><view class="field textarea-field"><block wx:if="{{r0}}"><textarea placeholder="告别语（选填）" class="farewell-input" maxlength="200" value="{{n}}" bindinput="{{o}}"/></block></view></view><button class="submit-btn" disabled="{{q}}" bindtap="{{r}}">{{p}}</button></view>