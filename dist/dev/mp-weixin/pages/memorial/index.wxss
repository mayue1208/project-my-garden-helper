/* uni-app 全局变量入口 */
page {
  background-color: #f6f8f6;
  font-size: 28rpx;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  line-height: 1.6;
  box-sizing: border-box;
}
view,
text,
scroll-view {
  box-sizing: border-box;
}
button {
  border-radius: 12rpx;
  font-size: 28rpx;
}
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.08);
}
.btn-primary {
  background: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}
.btn-primary[disabled] {
  opacity: 0.5;
}
.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #8c8c8c;
}
.empty-state .sub {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
}
.fab {
  position: fixed;
  bottom: 160rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  color: #ffffff;
  font-size: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.12);
  z-index: 100;
}
.page {
  padding-bottom: 120rpx;
}
.stats-bar {
  margin: 16rpx 24rpx;
  padding: 16rpx;
  text-align: center;
}
.stats-text {
  font-size: 28rpx;
  color: #8c8c8c;
}
.section {
  padding: 0 24rpx 20rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1a1a2e;
  display: block;
  margin-bottom: 16rpx;
}
.memorial-card {
  display: flex;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}
.thumb.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f5e9;
  font-size: 50rpx;
}
.info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a2e;
}
.reason {
  font-size: 26rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
}
.farewell {
  font-size: 22rpx;
  color: #bfbfbf;
  font-style: italic;
  margin-top: 8rpx;
}
.fab {
  position: fixed;
  bottom: 100rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  color: #ffffff;
  font-size: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.12);
  z-index: 10;
}