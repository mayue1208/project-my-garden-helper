/* uni-app 全局变量入口 */
page {
  background-color: #f6f8f6;
  font-size: 28rpx;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  line-height: 1.6;
  box-sizing: border-box;
}
view,
text,
scroll-view {
  box-sizing: border-box;
}
button {
  border-radius: 12rpx;
  font-size: 28rpx;
}
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.08);
}
.btn-primary {
  background: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}
.btn-primary[disabled] {
  opacity: 0.5;
}
.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #8c8c8c;
}
.empty-state .sub {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
}
.fab {
  position: fixed;
  bottom: 160rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  color: #ffffff;
  font-size: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.12);
  z-index: 100;
}
.page {
  padding: 20rpx;
}
.room-list {
  margin-bottom: 30rpx;
}
.room-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 16rpx;
}
.room-info {
  display: flex;
  align-items: center;
}
.room-icon {
  margin-right: 12rpx;
}
.room-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a2e;
}
.default-tag {
  font-size: 22rpx;
  color: #8c8c8c;
  background: #e8f5e9;
  padding: 2rpx 12rpx;
  border-radius: 30rpx;
  margin-left: 12rpx;
}
.actions {
  display: flex;
  gap: 20rpx;
}
.action-btn {
  font-size: 26rpx;
  color: #07c160;
}
.action-btn.danger {
  color: #e64340;
}
.add-btn {
  width: 100%;
  background: #ffffff;
  color: #07c160;
  border: 2rpx dashed #07c160;
  margin-top: 30rpx;
}