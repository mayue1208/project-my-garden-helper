<view class="page"><view class="room-list"><view wx:for="{{a}}" wx:for-item="room" wx:key="f" class="room-item card"><view class="room-info"><text class="room-icon">🏠</text><text class="room-name">{{room.a}}</text><text wx:if="{{room.b}}" class="default-tag">默认</text></view><view class="actions"><text class="action-btn" bindtap="{{room.c}}">编辑</text><text wx:if="{{room.d}}" class="action-btn danger" bindtap="{{room.e}}">删除</text></view></view></view><button class="add-btn btn-primary" bindtap="{{b}}">+ 添加房间</button></view>