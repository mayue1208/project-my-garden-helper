<view class="page"><view class="form card"><view class="photo-section"><text class="form-label">照片</text><view class="photo-grid"><view wx:for="{{a}}" wx:for-item="img" wx:key="c" class="photo-item"><image src="{{img.a}}" mode="aspectFill"/><text class="del-btn" bindtap="{{img.b}}">✕</text></view><view wx:if="{{b}}" class="add-photo" bindtap="{{c}}"><text class="plus">+</text></view></view></view><view class="field"><text class="form-label">事件类型</text><picker bindchange="{{e}}" range="{{f}}"><text class="value-text">{{d}}</text></picker></view><view class="field"><text class="form-label">日期</text><picker mode="date" bindchange="{{h}}"><text class="value-text">{{g}}</text></picker></view><view class="field textarea-field"><block wx:if="{{r0}}"><textarea placeholder="描述一下（选填）" class="desc-input" maxlength="200" value="{{i}}" bindinput="{{j}}"/></block></view></view><button class="submit-btn btn-primary" disabled="{{l}}" bindtap="{{m}}">{{k}}</button></view>