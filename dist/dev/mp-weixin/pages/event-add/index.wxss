/* uni-app 全局变量入口 */
page {
  background-color: #f6f8f6;
  font-size: 28rpx;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  line-height: 1.6;
  box-sizing: border-box;
}
view,
text,
scroll-view {
  box-sizing: border-box;
}
button {
  border-radius: 12rpx;
  font-size: 28rpx;
}
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.08);
}
.btn-primary {
  background: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}
.btn-primary[disabled] {
  opacity: 0.5;
}
.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #8c8c8c;
}
.empty-state .sub {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
}
.fab {
  position: fixed;
  bottom: 160rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  color: #ffffff;
  font-size: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.12);
  z-index: 100;
}
.page {
  padding: 20rpx;
}
.form {
  padding: 24rpx;
}
.photo-section {
  margin-bottom: 24rpx;
}
.form-label {
  font-size: 28rpx;
  color: #1a1a2e;
  display: block;
  margin-bottom: 16rpx;
}
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.photo-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
}
.photo-item image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}
.del-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #e64340;
  color: #ffffff;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 24rpx;
}
.add-photo {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #e8e8e8;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f0faf3;
}
.add-photo .plus {
  font-size: 60rpx;
  color: #07c160;
}
.field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.field.textarea-field {
  flex-direction: column;
  align-items: stretch;
  border-bottom: none;
  padding-bottom: 0;
}
.value-text {
  font-size: 28rpx;
  color: #1a1a2e;
}
.desc-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  line-height: 1.5;
}
.submit-btn {
  margin: 40rpx 20rpx;
  border-radius: 30rpx;
}