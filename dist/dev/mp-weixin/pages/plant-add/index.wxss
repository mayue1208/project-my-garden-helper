/* uni-app 全局变量入口 */
page {
  background-color: #f6f8f6;
  font-size: 28rpx;
  color: #1a1a2e;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  line-height: 1.6;
  box-sizing: border-box;
}
view,
text,
scroll-view {
  box-sizing: border-box;
}
button {
  border-radius: 12rpx;
  font-size: 28rpx;
}
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.08);
}
.btn-primary {
  background: #07c160;
  color: #ffffff;
  border: none;
  border-radius: 30rpx;
  padding: 16rpx 30rpx;
  font-size: 28rpx;
}
.btn-primary[disabled] {
  opacity: 0.5;
}
.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #8c8c8c;
}
.empty-state .sub {
  display: block;
  font-size: 24rpx;
  margin-top: 12rpx;
}
.fab {
  position: fixed;
  bottom: 160rpx;
  right: 30rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #07c160;
  color: #ffffff;
  font-size: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.12);
  z-index: 100;
}
.page {
  padding: 20rpx;
}
.form {
  padding: 24rpx;
}
.photo-upload {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 24rpx;
}
.photo-upload .preview {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}
.photo-upload .placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  border: 2rpx dashed #e8e8e8;
  border-radius: 16rpx;
  background: #f0faf3;
}
.photo-upload .placeholder .plus {
  font-size: 60rpx;
  color: #07c160;
}
.photo-upload .placeholder .hint {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
}
.field {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.field:last-child {
  border-bottom: none;
}
.label {
  width: 140rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  flex-shrink: 0;
}
.input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a2e;
}
.value-text {
  font-size: 28rpx;
  color: #1a1a2e;
}
.section-title {
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx 0 16rpx;
  color: #1a1a2e;
}
.care-configs {
  padding: 20rpx 24rpx;
}
.care-config-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.care-config-item:last-child {
  border-bottom: none;
}
.care-label-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.care-label {
  font-size: 28rpx;
  color: #1a1a2e;
}
.care-input-group {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #8c8c8c;
}
.num-input {
  width: 80rpx;
  text-align: center;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  margin: 0 12rpx;
  padding: 8rpx;
  font-size: 28rpx;
}
.note-field {
  margin-top: 16rpx;
}
.note-field .note-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  line-height: 1.5;
}
.submit-btn {
  margin: 40rpx 20rpx;
  border-radius: 30rpx;
}