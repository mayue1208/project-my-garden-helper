<view class="page"><scroll-view wx:if="{{a}}" scroll-x class="family-tabs"><view wx:for="{{b}}" wx:for-item="f" wx:key="b" class="{{['tab-item', f.c && 'active']}}" bindtap="{{f.d}}"><text class="tab-text">{{f.a}}</text></view></scroll-view><view class="section card"><view class="field"><text class="label">家庭名</text><text class="value">{{c}}</text><text wx:if="{{d}}" class="edit-link" bindtap="{{e}}">修改</text></view><view class="field"><text class="label">邀请码</text><text class="value">{{f}}</text><text class="edit-link" bindtap="{{g}}">复制</text></view></view><view class="section card"><text class="section-title">家人 ({{h}})</text><view wx:for="{{i}}" wx:for-item="m" wx:key="e" class="member-item"><view class="member-avatar-circle"><text class="avatar-text">{{m.a}}</text></view><view class="member-info"><text class="member-name">{{m.b}}</text><text class="member-role">{{m.c}}</text></view><text class="view-link" bindtap="{{m.d}}">查看→</text></view><view wx:if="{{j}}" class="empty-hint"> 暂无成员 </view></view><view class="section card"><text class="section-title">房间管理 ({{k}})</text><view wx:for="{{l}}" wx:for-item="room" wx:key="e" class="room-item"><view class="room-info"><text class="room-icon">🏠</text><text class="room-name">{{room.a}}</text><text wx:if="{{room.b}}" class="default-tag">默认</text></view><view class="room-actions"><text class="edit-link" bindtap="{{room.c}}">修改</text><text class="delete-link" bindtap="{{room.d}}">删除</text></view></view><view wx:if="{{m}}" class="empty-hint"> 暂无房间 </view><view class="add-room-btn" bindtap="{{n}}"><text>+ 添加房间</text></view></view></view>