/button><button class="sheet-confirm" bindtap="{{z}}" disabled="{{A}}">{{y}}</button></view></view><view wx:if="{{B}}" class="overlay" bindtap="{{C}}"/><view wx:if="{{D}}" class="sheet-panel"><text class="sheet-title">修改资料</text><view class="sheet-body"><button class="avatar-picker-btn" open-type="chooseAvatar" bindchooseavatar="{{G}}"><image wx:if="{{E}}" src="{{F}}" class="avatar-preview" mode="aspectFill"/><view wx:else class="avatar-preview avatar-placeholder-sm"><text class="placeholder-sm-text">点击更换头像</text></view></button><input type="nickname" value="{{H}}" class="nickname-input" placeholder="请输入昵称" bindblur="{{I}}"/></view><view class="sheet-actions"><button class="sheet-cancel" bindtap="{{J}}">取消</button><button class="sheet-confirm" bindtap="{{L}}" disabled="{{M}}">{{K}}</button></view></view><view wx:if="{{N}}" class="overlay" bindtap="{{O}}"/><view wx:if="{{P}}" class="dialog-panel"><text class="dialog-title">加入家庭</text><input placeholder="输入6位邀请码" class="dialog-input" maxlength="6" value="{{Q}}" bindinput="{{R}}"/><view class="dialog-actions"><button class="dialog-cancel" bindtap="{{S}}">取消</button><button class="dialog-confirm" disabled="{{U}}" bindtap="{{V}}">{{T}}</button></view></view><view wx:if="{{W}}" class="overlay" bindtap="{{X}}"/><view wx:if="{{Y}}" class="dialog-panel"><text class="dialog-title">创建家庭</text><input placeholder="输入家庭名称" class="dialog-input" maxlength="20" value="{{Z}}" bindinput="{{aa}}"/><view class="dialog-actions"><button class="dialog-cancel" bindtap="{{ab}}">取消</button><button class="dialog-confirm" disabled="{{ad}}" bindtap="{{ae}}">{{ac}}</button></view></view></view>