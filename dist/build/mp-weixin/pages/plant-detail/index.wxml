<view class="page"><view class="header card"><image wx:if="{{a}}" src="{{b}}" class="cover" mode="aspectFill"/><view wx:else class="cover placeholder">🌱</view><view class="info"><text class="name">{{c}}</text><text class="species">{{d}}</text><text class="meta">📍 {{e}}</text><text class="meta">📅 购入：{{f}}</text></view></view><view class="section card"><text class="section-title">养护周期</text><view wx:for="{{g}}" wx:for-item="cfg" wx:key="g" class="config-item"><view class="config-header"><text>{{cfg.a}} {{cfg.b}}</text><switch checked="{{cfg.c}}" bindchange="{{cfg.d}}" color="#07c160"/></view><view class="config-detail"> 每 {{cfg.e}} 天 </view><text class="last-time"> 上次：{{cfg.f}}</text></view><view wx:if="{{h}}" class="empty-hint">暂无养护周期设置</view></view><view class="section card"><view class="section-header"><text class="section-title">最近养护</text><text class="section-more" bindtap="{{i}}">全部记录 →</text></view><view wx:for="{{j}}" wx:for-item="r" wx:key="f" class="record-item"><text>{{r.a}} {{r.b}}</text><text class="record-time">{{r.c}}</text><text wx:if="{{r.d}}" class="record-who">{{r.e}}</text></view><view wx:if="{{k}}" class="empty-hint">暂无养护记录</view></view><view class="section card"><view class="section-header"><text class="section-title">成长记录</text><text class="section-more" bindtap="{{l}}">查看完整时间线 →</text></view><view wx:for="{{m}}" wx:for-item="e" wx:key="e" class="event-item"><image wx:if="{{e.a}}" src="{{e.b}}" class="event-thumb" mode="aspectFill"/><view class="event-info"><text>{{e.c}}</text><text class="event-date">{{e.d}}</text></view></view><view wx:if="{{n}}" class="empty-hint">暂无成长记录</view></view><view class="actions"><button class="action-btn edit-btn" bindtap="{{o}}">编辑</button><button class="action-btn memorial-btn" bindtap="{{p}}">移入纪念碑</button></view></view>