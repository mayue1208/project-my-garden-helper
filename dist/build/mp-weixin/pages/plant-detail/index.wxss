page{background-color:#f6f8f6;font-size:28rpx;color:#1a1a2e;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;line-height:1.6;box-sizing:border-box}view,text,scroll-view{box-sizing:border-box}button{border-radius:12rpx;font-size:28rpx}.card{background:#fff;border-radius:16rpx;padding:20rpx;box-shadow:0 2rpx 8rpx rgba(7,193,96,.08)}.btn-primary{background:#07c160;color:#fff;border:none;border-radius:30rpx;padding:16rpx 30rpx;font-size:28rpx}.btn-primary[disabled]{opacity:.5}.empty-state{text-align:center;padding:200rpx 0;color:#8c8c8c}.empty-state .sub{display:block;font-size:24rpx;margin-top:12rpx}.fab{position:fixed;bottom:160rpx;right:30rpx;width:100rpx;height:100rpx;border-radius:50%;background:#07c160;color:#fff;font-size:50rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(7,193,96,.12);z-index:100}.page{padding:20rpx 20rpx 100rpx}.header{display:flex;padding:24rpx;margin-bottom:16rpx}.cover{width:240rpx;height:240rpx;border-radius:16rpx;flex-shrink:0}.cover.placeholder{display:flex;align-items:center;justify-content:center;background:#e8f5e9;font-size:80rpx}.info{margin-left:24rpx;display:flex;flex-direction:column;justify-content:center}.name{font-size:44rpx;font-weight:700;color:#1a1a2e}.species,.meta{font-size:36rpx;color:#1a1a2e;margin-top:8rpx}.section{padding:24rpx;margin-bottom:16rpx}.section-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16rpx}.section-title{font-size:36rpx;font-weight:700;color:#1a1a2e}.section-more{font-size:28rpx;color:#07c160}.config-item{padding:20rpx 0;border-bottom:1rpx solid #f0f0f0}.config-item:last-child{border-bottom:none}.config-header{display:flex;justify-content:space-between;align-items:center;font-size:32rpx}.config-detail{font-size:32rpx;color:#1a1a2e;margin-top:8rpx}.last-time{font-size:30rpx;color:#bfbfbf}.record-item,.event-item{display:flex;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #f0f0f0;font-size:30rpx}.record-item:last-child,.event-item:last-child{border-bottom:none}.record-time,.event-date{font-size:26rpx;color:#bfbfbf;margin-left:20rpx}.record-who{font-size:28rpx;color:#8c8c8c;margin-left:auto}.event-thumb{width:80rpx;height:80rpx;border-radius:8rpx;margin-right:16rpx;flex-shrink:0}.event-info{display:flex;flex-direction:column;font-size:28rpx}.empty-hint{padding:20rpx;text-align:center;color:#8c8c8c;font-size:26rpx}.actions{padding:30rpx 24rpx;display:flex;flex-direction:column;gap:16rpx}.action-btn{width:100%;border-radius:30rpx;font-size:30rpx}.edit-btn{background:#07c160;color:#fff}.memorial-btn{background:#fce4ec;color:#c62828;border:none}
