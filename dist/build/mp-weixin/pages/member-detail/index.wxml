<view class="page"><view class="header card"><text class="user-name">{{a}}</text><text class="count">共 {{b}} 条操作记录</text></view><view wx:if="{{c}}" class="empty-state"><text>暂无操作记录</text></view><view wx:for="{{d}}" wx:for-item="group" wx:key="c" class="date-group"><text class="date-label">{{group.a}}</text><view wx:for="{{group.b}}" wx:for-item="op" wx:key="d" class="op-group card"><text class="op-type">{{op.a}} {{op.b}}</text><text class="op-plants">{{op.c}}</text></view></view></view>