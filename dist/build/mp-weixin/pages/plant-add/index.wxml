<view class="page"><view class="form card"><view class="photo-upload" bindtap="{{c}}"><image wx:if="{{a}}" src="{{b}}" class="preview" mode="aspectFill"/><view wx:else class="placeholder"><text class="plus">+</text><text class="hint">添加照片</text></view></view><view class="field"><text class="label">名称 *</text><input placeholder="植物名称" class="input" maxlength="20" value="{{d}}" bindinput="{{e}}"/></view><view class="field"><text class="label">品种</text><input placeholder="如：龟背竹" class="input" value="{{f}}" bindinput="{{g}}"/></view><view class="field"><text class="label">昵称</text><input placeholder="给植物起个名字" class="input" maxlength="20" value="{{h}}" bindinput="{{i}}"/></view><view class="field"><text class="label">房间</text><picker bindchange="{{k}}" range="{{l}}"><text class="value-text">{{j}}</text></picker></view><view class="field"><text class="label">购入日期</text><picker mode="date" bindchange="{{n}}"><text class="value-text">{{m}}</text></picker></view></view><view class="section-title">养护周期（选填，可后续修改）</view><view class="care-configs card"><view wx:for="{{o}}" wx:for-item="ct" wx:key="f" class="care-config-item"><view class="care-label-row"><switch checked="{{ct.a}}" bindchange="{{ct.b}}" color="#07c160"/><text class="care-label">{{ct.c}}</text></view><view class="care-input-group"><text>每</text><input type="number" class="num-input" value="{{ct.d}}" bindinput="{{ct.e}}"/><text>天</text></view></view></view><view class="field card note-field"><block wx:if="{{r0}}"><textarea placeholder="备注（选填）" class="note-input" maxlength="200" value="{{p}}" bindinput="{{q}}"/></block></view><button class="submit-btn btn-primary" disabled="{{s}}" bindtap="{{t}}">{{r}}</button></view>