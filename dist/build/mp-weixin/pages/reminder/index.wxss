page{background-color:#f6f8f6;font-size:28rpx;color:#1a1a2e;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;line-height:1.6;box-sizing:border-box}view,text,scroll-view{box-sizing:border-box}button{border-radius:12rpx;font-size:28rpx}.card{background:#fff;border-radius:16rpx;padding:20rpx;box-shadow:0 2rpx 8rpx rgba(7,193,96,.08)}.btn-primary{background:#07c160;color:#fff;border:none;border-radius:30rpx;padding:16rpx 30rpx;font-size:28rpx}.btn-primary[disabled]{opacity:.5}.empty-state{text-align:center;padding:200rpx 0;color:#8c8c8c}.empty-state .sub{display:block;font-size:24rpx;margin-top:12rpx}.fab{position:fixed;bottom:160rpx;right:30rpx;width:100rpx;height:100rpx;border-radius:50%;background:#07c160;color:#fff;font-size:50rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(7,193,96,.12);z-index:100}.page{padding-bottom:20rpx}.filter-bar{display:flex;align-items:center;justify-content:space-between;padding:16rpx 24rpx;margin:0 20rpx 16rpx}.filter-text{font-size:28rpx;color:#1a1a2e}.time-tabs{display:flex;background:#f0f0f0;border-radius:30rpx;overflow:hidden}.time-tabs text{padding:8rpx 24rpx;font-size:26rpx;transition:all .2s}.time-tabs text.active{background:#e8f5e9;color:#1b8a3d}.quick-btn{font-size:36rpx;line-height:1}.date-group{padding:0 24rpx 20rpx}.date-title{font-size:32rpx;font-weight:700;color:#1a1a2e;display:block;margin-bottom:12rpx;padding:0 12rpx}.overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.5);z-index:99}.delay-panel{position:fixed;bottom:0;left:0;right:0;background:#fff;padding:30rpx;border-radius:16rpx 16rpx 0 0;z-index:100}.delay-title{font-size:32rpx;font-weight:700;color:#1a1a2e;text-align:center;margin-bottom:20rpx}.delay-option{padding:24rpx 0;font-size:30rpx;border-bottom:1rpx solid #f0f0f0;text-align:center;color:#1a1a2e}.cancel-delay{margin-top:20rpx;background:#f0f0f0;color:#8c8c8c;border:none;border-radius:30rpx}
