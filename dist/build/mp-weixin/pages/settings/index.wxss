page{background-color:#f6f8f6;font-size:28rpx;color:#1a1a2e;font-family:-apple-system,BlinkMacSystemFont,Segoe UI,Roboto,sans-serif;line-height:1.6;box-sizing:border-box}view,text,scroll-view{box-sizing:border-box}button{border-radius:12rpx;font-size:28rpx}.card{background:#fff;border-radius:16rpx;padding:20rpx;box-shadow:0 2rpx 8rpx rgba(7,193,96,.08)}.btn-primary{background:#07c160;color:#fff;border:none;border-radius:30rpx;padding:16rpx 30rpx;font-size:28rpx}.btn-primary[disabled]{opacity:.5}.empty-state{text-align:center;padding:200rpx 0;color:#8c8c8c}.empty-state .sub{display:block;font-size:24rpx;margin-top:12rpx}.fab{position:fixed;bottom:160rpx;right:30rpx;width:100rpx;height:100rpx;border-radius:50%;background:#07c160;color:#fff;font-size:50rpx;display:flex;align-items:center;justify-content:center;box-shadow:0 8rpx 24rpx rgba(7,193,96,.12);z-index:100}.page{padding:20rpx}.section{padding:24rpx;margin-bottom:16rpx}.section-title{font-size:30rpx;color:#8c8c8c;display:block;margin-bottom:16rpx}.value-text{font-size:32rpx;color:#1a1a2e}.switch-item{display:flex;justify-content:space-between;align-items:center;padding:16rpx 0;border-bottom:1rpx solid #f0f0f0}.switch-item:last-child{border-bottom:none}.switch-label{font-size:30rpx;color:#1a1a2e}.info-row{display:flex;justify-content:space-between;padding:16rpx 0;font-size:30rpx;color:#1a1a2e}.logout-section{margin-top:80rpx;text-align:center;padding:24rpx}.logout-text{font-size:30rpx;color:#ff4d4f}.clear-item{padding:16rpx 0}.clear-text{font-size:28rpx;color:#ff4d4f;display:block}.clear-hint{font-size:22rpx;color:#bfbfbf;margin-top:8rpx;display:block}
