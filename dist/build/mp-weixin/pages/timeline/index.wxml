<view class="page"><view class="timeline-header"><text class="plant-name">{{a}} 的成长记录</text><text class="add-btn" bindtap="{{b}}">+ 记录</text></view><view wx:if="{{c}}" class="empty-state"><text>{{d}}</text><text class="sub">开始记录植物的成长吧</text></view><view class="timeline"><view wx:for="{{e}}" wx:for-item="group" wx:key="c" class="month-group"><view class="month-header"><text class="month-label">{{group.a}}</text><view class="month-line"/></view><view wx:for="{{group.b}}" wx:for-item="e" wx:key="g" class="event-node"><view class="dot"/><view class="event-card card"><image wx:if="{{e.a}}" src="{{e.b}}" class="event-photo" mode="aspectFill"/><view class="event-info"><text class="event-type">{{e.c}}</text><text class="event-date-text">{{e.d}}</text><text wx:if="{{e.e}}" class="event-desc">{{e.f}}</text></view></view></view></view></view></view>